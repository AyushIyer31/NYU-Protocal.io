# Copy this file to variables.env and fill in your own values.
# variables.env is gitignored so your secrets never get committed.

# LLM provider: "ollama" for local dev (no API key, runs on your machine),
# "claude" for hosted Claude (no GPU needed), or "openai" for OpenAI API.
# Can be overridden per-request via the /chat endpoint's provider parameter.
LLM_PROVIDER=ollama

# --- Local Ollama (used when LLM_PROVIDER=ollama) ---
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434
EXECUTION_STRATEGY=agentic

# --- Hosted Claude (used when LLM_PROVIDER=claude or requested via /chat) ---
# Get a key at https://console.anthropic.com . CLAUDE_MODEL defaults to
# claude-sonnet-4-6; claude-haiku-4-5 is cheaper for this high-volume workload.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# --- OpenAI (used when LLM_PROVIDER=openai or requested via /chat) ---
# Get a key at https://platform.openai.com/api-keys . OPENAI_MODEL defaults to
# gpt-4o-mini (cheapest). Other options: gpt-4o (latest), gpt-4-turbo.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# --- Google Gemini (used when LLM_PROVIDER=gemini or requested via /chat) ---
# Get a key at https://aistudio.google.com/apikey (keys start with "AIza...").
# GEMINI_MODEL defaults to gemini-2.0-flash. Others: gemini-2.0-flash, gemini-1.5-pro.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# --- PubMed / NCBI E-utilities (blended into search results) ---
# NCBI_API_KEY is optional but recommended: raises the E-utilities rate limit
# from 3 to 10 req/sec. Free at https://account.ncbi.nlm.nih.gov -> Account
# Settings -> API Key Management. Search degrades to protocols.io-only if unset/down.
NCBI_API_KEY=your_ncbi_api_key_here
# Unpaywall (final open-access full-text fallback) requires a contact email.
UNPAYWALL_EMAIL=your_email@example.com

# protocols.io credentials — get yours at https://www.protocols.io/developers
# After clicking "ACTIVATE OPEN API ACCESS", paste your client_id and client_secret.
# fetch_protocols.py will exchange them for a token and save it automatically,
# or you can paste a PROTOCOLS_IO_TOKEN directly.
PROTOCOLS_IO_CLIENT_ID=your_client_id_here
PROTOCOLS_IO_CLIENT_SECRET=your_client_secret_here
PROTOCOLS_IO_TOKEN=your_token_here
