# Copy this file to variables.env and fill in your own values.
# variables.env is gitignored so your secrets never get committed.

# LLM provider: "ollama" for local dev (no API key, runs on your machine),
# or "claude" for hosted/always-on deployments (no GPU needed on the host).
LLM_PROVIDER=ollama

# --- Local Ollama (used when LLM_PROVIDER=ollama) ---
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434
EXECUTION_STRATEGY=agentic

# --- Hosted Claude (used when LLM_PROVIDER=claude) ---
# Get a key at https://console.anthropic.com . CLAUDE_MODEL defaults to
# claude-sonnet-4-6; claude-haiku-4-5 is cheaper for this high-volume workload.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# protocols.io credentials — get yours at https://www.protocols.io/developers
# After clicking "ACTIVATE OPEN API ACCESS", paste your client_id and client_secret.
# fetch_protocols.py will exchange them for a token and save it automatically,
# or you can paste a PROTOCOLS_IO_TOKEN directly.
PROTOCOLS_IO_CLIENT_ID=your_client_id_here
PROTOCOLS_IO_CLIENT_SECRET=your_client_secret_here
PROTOCOLS_IO_TOKEN=your_token_here
