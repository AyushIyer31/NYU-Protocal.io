  "materials_text": "{\"blocks\":[{\"key\":\"5qeju\",\"text\":\"Tryptone\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"2c9mf\",\"text\":\"Yeast Extract\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"f9can\",\"text\":\"NaCl\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"5bpnt\",\"text\":\"KCl\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"cabmc\",\"text\":\"MgCl2\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[{\"style\":\"sub\",\"offset\":4,\"length\":1}],\"entityRanges\":[],\"data\":{}},{\"key\":\"bgjiv\",\"text\":\"MgSO4\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[{\"style\":\"sub\",\"offset\":4,\"length\":1}],\"entityRanges\":[],\"data\":{}},{\"key\":\"dsape\",\"text\":\"Glucose\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[{\"style\":\"sub\",\"offset\":0,\"length\":7}],\"entityRanges\":[],\"data\":{}}],\"entityMap\":{}}",
  "steps": [
    "Total Volume = 100ml",
    "Weigh 2g of Tryptone into a 150 ml beaker Add 0.5g of Yeast Extract Add 0.058g of NaCl [10mM] Add 0.019g KCl [2.5mM] Add 1mL 2M MgCl 2 [10mM] Add 0.12g MgSO 4 [10mM] Top up with distilled water to reach the 100ml mark",
    "Autoclave solution at 121 o C, 0.1MPa for 15 -20 minutes",
    "Allow the solution to cool to about 50 o C Add 0.396g of Glucose [20mM]",
    "Sterilize the final solution by passing it through a 0.2 µm filter. SOC medium can be stored at room temperature and is stable for several years."
  ],
