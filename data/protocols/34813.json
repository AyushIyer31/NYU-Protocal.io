  "steps": [
    "Weigh out Tris base 3.13 g",
    "Weigh out Tris HCl 27.45 g",
    "Weigh out sodium chloride 88 g",
    "Dissolve in MilliQ water 900 mL",
    "Measure and adjust to pH 7.5 with concentrated HCl and/or NaOH",
    "Add MilliQ water to a final volume of 1 L"
