  "warning": "{\"blocks\":[{\"key\":\"8fr60\",\"text\":\"Concentrated hydrochloric acid is corrosive by all exposure routes. Always work with concentrated HCl in a fume hood while wearing appropriate PPE.\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":[]}],\"entityMap\":{}}",
