  "guidelines": "{\"blocks\":[{\"key\":\"53od3\",\"text\":\"PMSF is hygroscopic and is highly unstable in aqueous solutions. A typical working solution of PMSF is 1mM.\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":[]},{\"key\":\"8r1mt\",\"text\":\"\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":[]},{\"key\":\"6stp3\",\"text\":\"PMSF is an anti-protease! Do not allow to come into contact with skin.\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[{\"key\":0,\"offset\":0,\"length\":4}],\"data\":[]},{\"key\":\"32ej8\",\"text\":\"\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":[]},{\"key\":\"8vthp\",\"text\":\"PMSF is inactivated in aqueous solutions. The rate of inactivation increases with increasing pH and is faster at 25°C than at 4°C. The half-life of a 20mM aqueous solution of PMSF is ~35 minutes at pH 8.0. This short half-life means that aqueous solutions of PMSF can be safely discarded after they have been rendered alkaline (pH \\u003e8.6) and stored for several hours at room temperature.\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":[]}],\"entityMap\":{\"0\":{\"type\":\"link\",\"mutability\":\"MUTABLE\",\"data\":{\"guid\":\"BF37EE9B57524FD1AD459A177FC729D9\",\"url\":\"http://store.p212121.com/pmsf/\"}}}}",
