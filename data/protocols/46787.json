  "materials_text": "{\"blocks\":[{\"key\":\"csv07\",\"text\":\"\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"9iikt\",\"text\":\"Commercial sea salts \\n\",\"type\":\"unordered-list-item\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"1h7f0\",\"text\":\"NaCl (CAS 7647-14-5)\\n\",\"type\":\"unordered-list-item\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"dfq0n\",\"text\":\"KCl (CAS 7447-40-7)\\n\",\"type\":\"unordered-list-item\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"201v7\",\"text\":\"CaCl2 (CAS 10043-52-4)\\n\",\"type\":\"unordered-list-item\",\"depth\":0,\"inlineStyleRanges\":[{\"style\":\"sub\",\"offset\":4,\"length\":2}],\"entityRanges\":[],\"data\":{}},{\"key\":\"4rvbl\",\"text\":\"MgCl2·6H2O (CAS 7791-18-6)\\n\",\"type\":\"unordered-list-item\",\"depth\":0,\"inlineStyleRanges\":[{\"style\":\"sub\",\"offset\":4,\"length\":1},{\"style\":\"sub\",\"offset\":8,\"length\":1}],\"entityRanges\":[],\"data\":{}},{\"key\":\"2lda6\",\"text\":\"MgSO4· 7H2O (CAS 10034-99-8)\\n\",\"type\":\"unordered-list-item\",\"depth\":0,\"inlineStyleRanges\":[{\"style\":\"sub\",\"offset\":4,\"length\":1},{\"style\":\"sub\",\"offset\":9,\"length\":1}],\"entityRanges\":[],\"data\":{}},{\"key\":\"2rqsf\",\"text\":\"NaH2PO4· H2O (CAS 10049-21-5)\\n\",\"type\":\"unordered-list-item\",\"depth\":0,\"inlineStyleRanges\":[{\"style\":\"sub\",\"offset\":3,\"length\":1},{\"style\":\"sub\",\"offset\":6,\"length\":1},{\"style\":\"sub\",\"offset\":10,\"length\":1}],\"entityRanges\":[],\"data\":{}},{\"key\":\"fgic7\",\"text\":\"Na2HPO4 Sigma (CAS 7558-79-4)\\n\",\"type\":\"unordered-list-item\",\"depth\":0,\"inlineStyleRanges\":[{\"style\":\"sub\",\"offset\":2,\"length\":1},{\"style\":\"sub\",\"offset\":6,\"length\":2}],\"entityRanges\":[],\"data\":{}}],\"entityMap\":{}}",
