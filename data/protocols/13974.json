  "materials_text": "{\"blocks\":[{\"key\":\"VJNw7\",\"text\":\"MATERIALS\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":null,\"entityRanges\":null,\"data\":null},{\"key\":\"6Gkur\",\"text\":\" \",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":null,\"entityRanges\":[{\"key\":0,\"offset\":0,\"length\":1}],\"data\":null},{\"key\":\"qtCVi\",\"text\":\" \",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":null,\"entityRanges\":[{\"key\":1,\"offset\":0,\"length\":1}],\"data\":null}],\"entityMap\":{\"0\":{\"type\":\"reagents\",\"mutability\":\"\",\"data\":{\"id\":127177,\"guid\":\"41A191D0341F11EE9D4302C0B41BC903\",\"name\":\"Poly(ethylene glycol) octyl ether\",\"mol_weight\":0,\"sku\":\"40530 \",\"url\":\"\",\"cas_number\":\"\",\"rrid\":\"\",\"vendor\":{\"id\":17,\"name\":\"Merck MilliporeSigma (Sigma-Aldrich)\",\"link\":\"http://sigmaaldrich.com\",\"is_requested\":false,\"image\":{\"source\":\"/img/vendors/placeholder.png\",\"placeholder\":\"/img/vendors/placeholder.png\"}},\"is_public\":true,\"can_edit\":false}},\"1\":{\"type\":\"reagents\",\"mutability\":\"\",\"data\":{\"id\":127178,\"guid\":\"41A19221341F11EE9D4302C0B41BC903\",\"name\":\"Bio-Beads™ SM-2 Resin\",\"mol_weight\":0,\"sku\":\"1523920\",\"url\":\"\",\"cas_number\":\"\",\"rrid\":\"\",\"vendor\":{\"id\":41,\"name\":\"Bio-Rad Laboratories\",\"link\":\"http://www.bio-rad.com/\",\"is_requested\":false,\"image\":{\"source\":\"/img/vendors/placeholder.png\",\"placeholder\":\"/img/vendors/placeholder.png\"}},\"is_public\":true,\"can_edit\":false}}}}",
  "steps": [
    "Giant Unilamellar Vesicles (GUVs) Preparation by Electroformation Method by Zehra Kahveci",
    "Prepare 2 eppendorfs containing 100 µL of 195 mM sucrose solution (freshly made in Hepes buffer 5mM pH 7.4) and add 100 µL of electroformation product into each eppendorf.",
    "Shake the Eppendorfs gently upside-down.",
    "Dilute the membrane transporter (~5mg/mL) in Poly(ethylene glycol) octyl ether ( o-poe ), 1:1 (v:v), total volume of 1µL.",
    "Add 1µL of membrane transporter:o-poe 1:1 (v:v) into Eppendorf 1 (SAMPLE)",
    "Add 1µL of o-poe into Eppendorf 2 (BLANK)",
    "Shake the SAMPLE and BLANK gently upside-down.",
    "Place both tubes on to a shaker, shake them at ~600 rpm. 01:00:00 Undetermined",
    "Add 2.5 mg Biobeads into both tubes.",
    "Store the SAMPLE and BLANK in the fridge at 4°C, overnight.",
    "Cut a pipette tip, collect the SAMPLE and the BLANK from each each eppendorf and put the SAMPLE and BLANK into new eppendorfs.",
    "The SAMPLE and the BLANK can be used in the following 4-5 days. (Store in the fridge).",
    "Shake the tubes upside-down, place them on to a shaker and shake them at ~600 rpm. 01:00:00 Undetermined"
  ],
