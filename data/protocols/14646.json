  "materials_text": "{\"blocks\":[{\"key\":\"F3VX7\",\"text\":\"MATERIALS\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":null,\"entityRanges\":null,\"data\":null},{\"key\":\"9D569\",\"text\":\" \",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":null,\"entityRanges\":[{\"key\":0,\"offset\":0,\"length\":1}],\"data\":null}],\"entityMap\":{\"0\":{\"type\":\"reagents\",\"mutability\":\"\",\"data\":{\"id\":179807,\"guid\":\"41A6103A341F11EE9D4302C0B41BC903\",\"name\":\"Z-Fix\",\"mol_weight\":0,\"sku\":\"NC9378601\",\"url\":\"https://www.fishersci.com/shop/products/z-fix-zinc-fixative-5-gal/nc9378601#?keyword=z-fix\\u0026content_id=179806\\u0026content_type_id=17\",\"cas_number\":\"\",\"rrid\":\"\",\"vendor\":{\"id\":31,\"name\":\"Fisher Scientific\",\"link\":\"https://www.fishersci.com/us/en/home.html\",\"is_requested\":false,\"image\":{\"source\":\"/img/vendors/placeholder.png\",\"placeholder\":\"/img/vendors/placeholder.png\"}},\"is_public\":true,\"can_edit\":false}}}}",
  "steps": [
    "This protocol is associated with Isolation of Human Pancreatic Islets of Langerhans for Research step 7.",
    "Label a 15ml conical tube with the internal identifier number (Rxxx) and “biopsy”.",
    "Following pancreas perfusion, use surgical scissors to excise a 5mm cubic piece of tissue from the tail of the pancreas.",
    "Transfer into a 15ml conical tube using forceps.",
    "Add 5ml Z-fix into the conical tube, and cap the tube.",
    "Store biopsy tube @4°C.",
    "After 24hrs in fixative the biopsy should be transferred into PBS and can be submitted to the Histology Core for processing into paraffin blocks and cut for slide preparation. Record the sample in the Histology Library Record and on REDCap. sample Histology Library Record: %s %s"
  ],
