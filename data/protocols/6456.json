  "materials_text": "{\"blocks\":[{\"key\":\"CaqIc\",\"text\":\"STEP MATERIALS\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":null,\"entityRanges\":null,\"data\":null},{\"key\":\"scBS9\",\"text\":\" \",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":null,\"entityRanges\":[{\"key\":0,\"offset\":0,\"length\":1}],\"data\":null},{\"key\":\"YIt08\",\"text\":\" \",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":null,\"entityRanges\":[{\"key\":1,\"offset\":0,\"length\":1}],\"data\":null}],\"entityMap\":{\"0\":{\"type\":\"reagents\",\"mutability\":\"\",\"data\":{\"id\":3271,\"guid\":\"410569D1341F11EE9D4302C0B41BC903\",\"name\":\"Glycerol \",\"mol_weight\":0,\"sku\":\"MRGE-4002\",\"url\":\"\",\"cas_number\":\"\",\"rrid\":\"\",\"vendor\":{\"id\":107,\"name\":\"growcells.com\",\"link\":\"http://growcells.com\",\"is_requested\":false,\"image\":{\"source\":\"/img/vendors/placeholder.png\",\"placeholder\":\"/img/vendors/placeholder.png\"}},\"is_public\":true,\"can_edit\":false}},\"1\":{\"type\":\"reagents\",\"mutability\":\"\",\"data\":{\"id\":3271,\"guid\":\"410569D1341F11EE9D4302C0B41BC903\",\"name\":\"Glycerol \",\"mol_weight\":0,\"sku\":\"MRGE-4002\",\"url\":\"\",\"cas_number\":\"\",\"rrid\":\"\",\"vendor\":{\"id\":107,\"name\":\"growcells.com\",\"link\":\"http://growcells.com\",\"is_requested\":false,\"image\":{\"source\":\"/img/vendors/placeholder.png\",\"placeholder\":\"/img/vendors/placeholder.png\"}},\"is_public\":true,\"can_edit\":false}}}}",
  "steps": [
    "Vortex a freshly lysed culture for 10 sec 00:00:10",
    "Add 1 mL of phage into each cryogenic vial undetermined",
    "Add 1 mL of 20% glycerol to each vial with phage undetermined Glycerol growcells.com Catalog #MRGE-4002",
    "Invert tubes several times",
    "Place immediately in a -80ºC freezer",
    "Remove cryogenic vials one at a time from the freezer",
    "Using a sterile pipette tip, scrape a small amount of frozen virus particles into a 20 mL mid-log culture",
    "Place cryogenic vials immediately back into the freezer",
    "Allow to incubate and lyse culture under constant light conditions appropriate for your specific culture"
