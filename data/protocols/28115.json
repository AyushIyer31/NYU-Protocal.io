  "steps": [
    "Add 450 µL Buffer QG into 2ml tube containing gel slice Buffer QG Contributed by users",
    "Incubate at 50 °C for 00:10:00",
    "Add 150 µL isopropanol to the sample and mix Isopropanol Contributed by users",
    "Transfer entire volume into QIAquick spin column",
    "Centrifuge at 13000 rpm for 00:01:00",
    "Discard flow through",
    "Add 750 µL Buffer PE to QIAquick spin column Buffer PE Contributed by users",
    "Centrifuge at 13000 rpm for 00:01:00",
    "Discard flow through",
    "Repeat steps 7 - 9",
    "Place spin column onto a new eppendorf tube",
    "Elute DNA by adding 30 µL Buffer EB to the center of QIAquick membrane Buffer EB Qiagen Catalog #19086",
    "Incubate at Room temperature for 00:04:00",
    "Centrifuge at 13000 rpm for 00:01:00",
    "Collect eluted DNA"
  ],
