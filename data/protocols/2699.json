  "materials_text": "{\"blocks\":[{\"key\":\"UaXz1\",\"text\":\"MATERIALS\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":null,\"entityRanges\":null,\"data\":null},{\"key\":\"vHqDO\",\"text\":\" \",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":null,\"entityRanges\":[{\"key\":0,\"offset\":0,\"length\":1}],\"data\":null},{\"key\":\"LtjcV\",\"text\":\" \",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":null,\"entityRanges\":[{\"key\":1,\"offset\":0,\"length\":1}],\"data\":null}],\"entityMap\":{\"0\":{\"type\":\"reagents\",\"mutability\":\"\",\"data\":{\"id\":2715,\"guid\":\"4104B54A341F11EE9D4302C0B41BC903\",\"name\":\"MilliQ water\",\"mol_weight\":0,\"sku\":\"\",\"url\":\"\",\"cas_number\":\"\",\"rrid\":\"\",\"vendor\":{\"id\":1,\"name\":\"Contributed by users\",\"link\":\"https://www.protocols.io\",\"is_requested\":false,\"image\":{\"source\":\"/img/vendors/1.png\",\"placeholder\":\"/img/vendors/1.png\"}},\"is_public\":true,\"can_edit\":false}},\"1\":{\"type\":\"reagents\",\"mutability\":\"\",\"data\":{\"id\":3157,\"guid\":\"410543A6341F11EE9D4302C0B41BC903\",\"name\":\"AA Cobalt Standard 1 mg/L\",\"mol_weight\":0,\"sku\":\"\",\"url\":\"\",\"cas_number\":\"\",\"rrid\":\"\",\"vendor\":{\"id\":1,\"name\":\"Contributed by users\",\"link\":\"https://www.protocols.io\",\"is_requested\":false,\"image\":{\"source\":\"/img/vendors/1.png\",\"placeholder\":\"/img/vendors/1.png\"}},\"is_public\":true,\"can_edit\":false}}}}",
  "steps": [
    "Rinse a 100 mL volumetric flask (that has been cleaned with 10% hydrocholoric acid cabinet) with pH 2 Milli-Q 3 times and Milli-Q 3 times.",
    "Fill the flask part way with Milli-Q and add 29.5 μl of the cobalt AA standard (1 mg L -1 ) to the Milli-Q. The final concentration will be 5 nmol L -1 .",
    "Carefully fill up to 100 mL Milli-Q using a squirt bottle and invert to mix. Save a small aliquot in a 5 mL clean bottle for a potential run later on the ICP-MS."
