  "materials_text": "{\"blocks\":[{\"key\":\"NVlE2\",\"text\":\"MATERIALS\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":null,\"entityRanges\":null,\"data\":null},{\"key\":\"CX29H\",\"text\":\" \",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":null,\"entityRanges\":[{\"key\":0,\"offset\":0,\"length\":1}],\"data\":null}],\"entityMap\":{\"0\":{\"type\":\"reagents\",\"mutability\":\"\",\"data\":{\"id\":127686,\"guid\":\"41A22EEA341F11EE9D4302C0B41BC903\",\"name\":\"Endo F2\",\"mol_weight\":0,\"sku\":\"E-EF02\",\"url\":\"https://www.qa-bio.com/product/endo-f2/\",\"cas_number\":\"\",\"rrid\":\"\",\"vendor\":{\"id\":393,\"name\":\"QA-Bio Inc\",\"link\":\"https://www.qa-bio.com\",\"is_requested\":false,\"image\":{\"source\":\"/img/vendors/placeholder.png\",\"placeholder\":\"/img/vendors/placeholder.png\"}},\"is_public\":true,\"can_edit\":false}}}}",
  "steps": [
    "Add up to 200 μg of glycoprotein to an Eppendorf tube. Adjust to 38 μl final volume with de-ionized water.",
    "Add 10 μl 5x Reaction Buffer 4.5",
    "Add 2.0 μl of Endo F2 to the reaction. Incubate 3 hours at 37°C.",
    "Monitor cleavage by SDS-PAGE."
