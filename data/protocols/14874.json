  "materials_text": "{\"blocks\":[{\"key\":\"uyUUl\",\"text\":\"MATERIALS\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":null,\"entityRanges\":null,\"data\":null},{\"key\":\"xYaHu\",\"text\":\" \",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":null,\"entityRanges\":[{\"key\":0,\"offset\":0,\"length\":1}],\"data\":null},{\"key\":\"YGpui\",\"text\":\" \",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":null,\"entityRanges\":[{\"key\":1,\"offset\":0,\"length\":1}],\"data\":null}],\"entityMap\":{\"0\":{\"type\":\"reagents\",\"mutability\":\"\",\"data\":{\"id\":3117,\"guid\":\"410536E2341F11EE9D4302C0B41BC903\",\"name\":\"0.5mm diameter glass beads\",\"mol_weight\":0,\"sku\":\"SI-BG05\",\"url\":\"http://www.scientificindustries.com/disruptorbeads.html\",\"cas_number\":\"\",\"rrid\":\"\",\"vendor\":{\"id\":96,\"name\":\"Scientific Industries, Inc.\",\"link\":\"http://www.scientificindustries.com/index.html\",\"is_requested\":false,\"image\":{\"source\":\"/img/vendors/placeholder.png\",\"placeholder\":\"/img/vendors/placeholder.png\"}},\"is_public\":true,\"can_edit\":false}},\"1\":{\"type\":\"reagents\",\"mutability\":\"\",\"data\":{\"id\":4321,\"guid\":\"4106E12F341F11EE9D4302C0B41BC903\",\"name\":\"Phosphate Buffered Saline\",\"mol_weight\":0,\"sku\":\"28374\",\"url\":\"\",\"cas_number\":\"\",\"rrid\":\"\",\"vendor\":{\"id\":95,\"name\":\"Thermo Fisher Scientific\",\"link\":\"https://www.thermofisher.com/us/en/home.html\",\"is_requested\":false,\"image\":{\"source\":\"/img/vendors/placeholder.png\",\"placeholder\":\"/img/vendors/placeholder.png\"}},\"is_public\":true,\"can_edit\":false}}}}",
  "steps": [
    "Collect 1 ml Synechocystis liquid culture and spin it down at 14,000 g for 5 min . Discard the supernatant and keep the pellets cool. 00:05:00, Centrifugation",
    "Resuspend the pellet from step 1 in 1 ml PBS Buffer (pH = 7.4). Transfer the solution into the prepared 1.5 ml tubes filled with glass beads. Keep the solution cool.",
    "Fill a 1.5 ml Eppendorf Tube with 400 ml glass beads (~0.5 mm) for each sample.",
    "Thoroughly vortex each sample for 1 min . Repeat the process five times . The supernatant should become blue-green and clear. 00:01:00, Vortex",
    "Spin down your vortexed sample for 5 min at 3,000 g at 4 °C . Transfer the supernatant into a fresh 2 ml Eppendorf tube and keep the supernatant cool. 00:05:00, Centrifugation",
    "Spin down your supernatant again at 14,000 g for 20 min at 4 °C . 00:20:00, Centrifugation",
    "Transfer the supernatant into a cuvette. The supernatant should appear clearly blue at this stage. Measure the extinction at 620 nm . Use PBS as a blank."
  ],
