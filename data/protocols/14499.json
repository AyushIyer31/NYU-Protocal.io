  "warning": "{\"blocks\":[{\"key\":\"clprg\",\"text\":\"\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":[]}],\"entityMap\":{}}",
  "materials_text": "{\"blocks\":[{\"key\":\"c41kU\",\"text\":\"MATERIALS\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":null,\"entityRanges\":null,\"data\":null},{\"key\":\"SAKOw\",\"text\":\" \",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":null,\"entityRanges\":[{\"key\":0,\"offset\":0,\"length\":1}],\"data\":null}],\"entityMap\":{\"0\":{\"type\":\"reagents\",\"mutability\":\"\",\"data\":{\"id\":127685,\"guid\":\"41A22E98341F11EE9D4302C0B41BC903\",\"name\":\"Endo F1\",\"mol_weight\":0,\"sku\":\"E-EF01\",\"url\":\"https://www.qa-bio.com/product/endo-f1/\",\"cas_number\":\"\",\"rrid\":\"\",\"vendor\":{\"id\":393,\"name\":\"QA-Bio Inc\",\"link\":\"https://www.qa-bio.com\",\"is_requested\":false,\"image\":{\"source\":\"/img/vendors/placeholder.png\",\"placeholder\":\"/img/vendors/placeholder.png\"}},\"is_public\":true,\"can_edit\":false}}}}",
  "steps": [
    "Add up to 200 μg of glycoprotein to an Eppendorf tube. Adjust to 38 μl final volume with de-ionized water.",
    "Add 10 μl 5x Reaction Buffer 5.5",
    "Add 2.0 μl of Endo F1 to the reaction",
    "Incubate 3 hours at 37°C.",
    "Monitor cleavage by SDS-PAGE."
