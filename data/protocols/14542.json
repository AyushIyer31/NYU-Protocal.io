s/1.png\"}},\"is_public\":true,\"can_edit\":false}},\"2\":{\"type\":\"reagents\",\"mutability\":\"\",\"data\":{\"id\":127703,\"guid\":\"41A23471341F11EE9D4302C0B41BC903\",\"name\":\"aluminun chloride\",\"mol_weight\":0,\"sku\":\"\",\"url\":\"\",\"cas_number\":\"\",\"rrid\":\"\",\"vendor\":{\"id\":17,\"name\":\"Merck MilliporeSigma (Sigma-Aldrich)\",\"link\":\"http://sigmaaldrich.com\",\"is_requested\":false,\"image\":{\"source\":\"/img/vendors/placeholder.png\",\"placeholder\":\"/img/vendors/placeholder.png\"}},\"is_public\":true,\"can_edit\":false}},\"3\":{\"type\":\"reagents\",\"mutability\":\"\",\"data\":{\"id\":127704,\"guid\":\"41A234C2341F11EE9D4302C0B41BC903\",\"name\":\"sodium carbonates\",\"mol_weight\":0,\"sku\":\"\",\"url\":\"\",\"cas_number\":\"\",\"rrid\":\"\",\"vendor\":{\"id\":17,\"name\":\"Merck MilliporeSigma (Sigma-Aldrich)\",\"link\":\"http://sigmaaldrich.com\",\"is_requested\":false,\"image\":{\"source\":\"/img/vendors/placeholder.png\",\"placeholder\":\"/img/vendors/placeholder.png\"}},\"is_public\":true,\"can_edit\":false}},\"4\":{\"type\":\"reagents\",\"mutability\":\"\",\"data\":{\"id\":127705,\"guid\":\"41A23512341F11EE9D4302C0B41BC903\",\"name\":\"catechin\",\"mol_weight\":0,\"sku\":\"\",\"url\":\"\",\"cas_number\":\"\",\"rrid\":\"\",\"vendor\":{\"id\":17,\"name\":\"Merck MilliporeSigma (Sigma-Aldrich)\",\"link\":\"http://sigmaaldrich.com\",\"is_requested\":false,\"image\":{\"source\":\"/img/vendors/placeholder.png\",\"placeholder\":\"/img/vendors/placeholder.png\"}},\"is_public\":true,\"can_edit\":false}}}}",
  "steps": [
    "An aliquot of sample (0.1 mL) was mixed with 0.4 ml distilled water in a 1.5 mL microcentrifuge tube.",
    "0.03 mL of 5% NaNO 2 was added and the mixture was allowed to react for 5 min.",
    "Following this, 0.03 mL of 10% AlCl 3 was added and the mixture stood for a further 5 min.",
    "Finally, the reaction mixture was treated with 0.2 mL of 1 M Na 2 CO 3 and 0.24 mL distilled water, and the absorbance at 510 nm.",
    "Catechin (Sigma-Aldrich) was used as the standard and the results were expressed as µg/mL of catechin equivalents (CE)."
