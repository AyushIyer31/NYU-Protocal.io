  "steps": [
    "Make 6M Urea solution by adding 108.11 mg of Urea to 300 µL of 50mM ammonium bicarbonate (NH4HCO3) containing protein. 00:04:00 Ammonium bicarbonate P212121 Catalog #CI-01682",
    "Add 20 µL of 1.5 M Tris pH 8.8. 00:02:00 Tris P212121 Catalog #RP-T60040",
    "Add 7.5 µL of 200mM TCEP and incubate for 1 hour at 37°C. 01:00:00 TCEP HCl P212121 Catalog #SV-TCEP",
    "Add 60 µL of 200mM iodoacetamide and vortex. Incubate for one hour at room temperature in a dark area. 01:02:00 Iodoacetamide P212121 Catalog #AK-U470",
    "Add 60 µL of 200mM DTT and vortex. Incubate for one hour at room temperature. 01:02:00 DTT P212121 Catalog #SV-DTT",
    "Aliquot 150 µL each into three 1.5 mL centrifuge tubes. 00:05:00",
    "Add 800 µL of 25mM ammonium bicarbonate to each tube to dilute the urea. 00:03:00",
    "Add 200 µL of MeOH to each tube. 00:03:00 Methanol P212121 Catalog #PA-33900HPLCCS4L",
    "Add Trypsin to protein at a ratio of 50 protein to 1 trypsin and incubate overnight at room temperature. Speedvac until dry. 24:05:00 Trypsin P212121 Catalog #RP-T70010",
    "Add 200 µL of molecular biology grade water to tubes three times and speedvac to reduce the ammonium bicarbonate. Store at -80°C. 00:03:00"
  ],
