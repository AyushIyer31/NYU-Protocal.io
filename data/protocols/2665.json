  "materials_text": "",
  "steps": [
    "Dissect tissues in 1X PBS and fix in 4% Paraformaldehyde for 20 minutes",
    "Rinse twice with 1X PBS",
    "Stain for 20 minutes in Oil Red O Solution",
    "Rinse 2X in water",
    "Mount in glycerol and image immediately"
