  "steps": [
    "Add 80% final volume of DI water to beaker",
    "Yeast Extract 1.5g/500mL Tryptone 2.5g/500mL Thymidine 150mg/500mL",
    "Add Yeast Extract, Tryptone, and Thymidine until fully dissolved",
    "Adjust pH to 5.5",
    "Autoclave on Liquid 20 minute cycle"
  ],
