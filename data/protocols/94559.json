  "materials_text": "{\"blocks\":[{\"key\":\"3kbn9\",\"text\":\"Hoechst 33342 (7 µM) \",\"type\":\"unordered-list-item\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"73te\",\"text\":\"propidium iodide (PI) (2 µM) (Invitrogen) \",\"type\":\"unordered-list-item\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"dhd2h\",\"text\":\"Axiovision 4.6 software (Carl Zeiss)\",\"type\":\"unordered-list-item\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}}],\"entityMap\":{}}",
  "steps": [
    "Stain neurons with Hoechst 33342 ( 7 micromolar (µM) ) and propidium iodide (PI) ( 2 micromolar (µM) ) (Invitrogen) at 37 °C for 00:05:00 .",
    "Capture images by a microscope and dead cells are automatically counted by Axiovision 4.6 software (Carl Zeiss).",
    "Subject background signals of the control group intensity.",
    "Calculate the neuronal death percentage by dividing the PI signal by the Hoechst 33342 signal."
  ],
