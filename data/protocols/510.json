  "steps": [
    "Fill 1L pyrex bottle with 700mL dH20",
    "Add 30.2g Tris base",
    "Add 144.2g glycine",
    "pH solution to 8.80 after disolution of tris and glycine",
    "Add 10g SDS (1% final)",
    "Fill to 1L with dH20"
