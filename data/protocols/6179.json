  "materials_text": "{\"blocks\":[{\"key\":\"GDysy\",\"text\":\"MATERIALS\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":null,\"entityRanges\":null,\"data\":null},{\"key\":\"L2nxX\",\"text\":\" \",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":null,\"entityRanges\":[{\"key\":0,\"offset\":0,\"length\":1}],\"data\":null},{\"key\":\"899xm\",\"text\":\" \",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":null,\"entityRanges\":[{\"key\":1,\"offset\":0,\"length\":1}],\"data\":null},{\"key\":\"FoK08\",\"text\":\" \",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":null,\"entityRanges\":[{\"key\":2,\"offset\":0,\"length\":1}],\"data\":null},{\"key\":\"JPMXQ\",\"text\":\" \",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":null,\"entityRanges\":[{\"key\":3,\"offset\":0,\"length\":1}],\"data\":null},{\"key\":\"Emmlk\",\"text\":\" \",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":null,\"entityRanges\":[{\"key\":4,\"offset\":0,\"length\":1}],\"data\":null},{\"key\":\"3IWw4\",\"text\":\" \",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":null,\"entityRanges\":[{\"key\":5,\"offset\":0,\"length\":1}],\"data\":null}],\"entityMap\":{\"0\":{\"type\":\"reagents\",\"mutability\":\"\",\"data\":{\"id\":4553,\"guid\":\"41072F2E341F11EE9D4302C0B41BC903\",\"name\":\"proteinase K containing buffer\",\"mol_weight\":0,\"sku\":\"\",\"url\":\"\",\"cas_number\":\"\",\"rrid\":\"\",\"vendor\":{\"id\":1,\"name\":\"Contributed by users\",\"link\":\"https://www.protocols.io\",\"is_requested\":false,\"image\":{\"source\":\"/img/vendors/1.png\",\"placeholder\":\"/img/vendors/1.png\"}},\"is_public\":true,\"can_edit\":false}},\"1\":{\"type\":\"reagents\",\"mutability\":\"\",\"data\":{\"id\":4554,\"guid\":\"41072F7D341F11EE9D4302C0B41BC903\",\"name\":\"organic solvents (phenol:chloroform)\",\"mol_weight\":0,\"sku\":\"\",\"url\":\"\",\"cas_number\":\"\",\"rrid\":\"\",\"vendor\":{\"id\":1,\"name\":\"Contributed by users\",\"link\":\"https://www.protocols.io\",\"is_requested\":false,\"image\":{\"source\":\"/img/vendors/1.png\",\"placeholder\":\"/img/vendors/1.png\"}},\"is_public\":true,\"can_edit\":false}},\"2\":{\"type\":\"reagents\",\"mutability\":\"\",\"data\":{\"id\":4555,\"guid\":\"41072FCF341F11EE9D4302C0B41BC903\",\"name\":\"MinElute columns\",\"mol_weight\":0,\"sku\":\"\",\"url\":\"\",\"cas_number\":\"\",\"rrid\":\"\",\"vendor\":{\"id\":25,\"name\":\"Qiagen\",\"link\":\"https://www.qiagen.com/us/products/\",\"is_requested\":false,\"image\":{\"source\":\"/img/vendors/placeholder.png\",\"placeholder\":\"/img/vendors/placeholder.png\"}},\"is_public\":true,\"can_edit\":false}},\"3\":{\"type\":\"reagents\",\"mutability\":\"\",\"data\":{\"id\":4557,\"guid\":\"41073076341F11EE9D4302C0B41BC903\",\"name\":\"PB buffer\",\"mol_weight\":0,\"sku\":\"19066\",\"url\":\"https://www.qiagen.com/us/shop/lab-basics/buffers-and-reagents/buffer-pb/#orderinginformation\",\"cas_number\":\"\",\"rrid\":\"\",\"vendor\":{\"id\":25,\"name\":\"Qiagen\",\"link\":\"https://www.qiagen.com/us/products/\",\"is_requested\":false,\"image\":{\"source\":\"/img/vendors/placeholder.png\",\"placeholder\":\"/img/vendors/placeholder.png\"}},\"is_public\":true,\"can_edit\":false}},\"4\":{\"type\":\"reagents\",\"mutability\":\"\",\"data\":{\"id\":4558,\"guid\":\"410730C8341F11EE9D4302C0B41BC903\",\"name\":\"Buffer PE\",\"mol_weight\":0,\"sku\":\"19065\",\"url\":\"https://www.qiagen.com/us/shop/lab-basics/buffers-and-reagents/buffer-pe/#orderinginformation\",\"cas_number\":\"\",\"rrid\":\"\",\"vendor\":{\"id\":25,\"name\":\"Qiagen\",\"link\":\"https://www.qiagen.com/us/products/\",\"is_requested\":false,\"image\":{\"source\":\"/img/vendors/placeholder.png\",\"placeholder\":\"/img/vendors/placeholder.png\"}},\"is_public\":true,\"can_edit\":false}},\"5\":{\"type\":\"reagents\",\"mutability\":\"\",\"data\":{\"id\":4559,\"guid\":\"4107311A341F11EE9D4302C0B41BC903\",\"name\":\"Buffer EB\",\"mol_weight\":0,\"sku\":\"19086\",\"url\":\"https://www.qiagen.com/us/shop/lab-basics/buffers-and-reagents/buffer-eb/#orderinginformation\",\"cas_number\":\"\",\"rrid\":\"\",\"vendor\":{\"id\":25,\"name\":\"Qiagen\",\"link\":\"https://www.qiagen.com/us/products/\",\"is_requested\":false,\"image\":{\"source\":\"/img/vendors/placeholder.png\",\"placeholder\":\"/img/vendors/placeholder.png\"}},\"is_public\":true,\"can_edit\":false}}}}",
  "steps": [
    "Digestion in a proteinase K containing buffer following Gilbert et al. 2007. Gilbert MTP, Tomsho LP, Rendulic S, Packard M, Drautz DI, Sher A, et al. Whole-genome shotgun sequencing of mitochondria from ancient hair shafts. Science. American Association for the Advancement of Science; 2007;317:1927–30.",
    "Pre-digest all samples at 56 °C for 1 hour. 01:00:00 Perform incubation with a rotation of the samples in an oven.",
    "Replace the buffer with fresh buffer.",
    "Perform a second 12-hour digest with the fresh buffer. 12:00:00 Perform incubation with a rotation of the samples in an oven.",
    "Purify digests using organic solvents (phenol:chloroform) and Qiagen MinElute columns (Qiagen, Hilden, DE) as described in the following steps:",
    "Mix digests with 8x modified PB buffer (Allentoft et al. 2015). Allentoft ME, Sikora M, Sjögren K-G, Rasmussen S, Rasmussen M, Stenderup J, et al. Population genomics of Bronze Age Eurasia. Nature. Nature Publishing Group; Dabney J, Knapp M, Glocke I et al. (2013) Complete mitochondrial genome sequence of a Middle Pleistocene cave bear reconstructed from ultrashort DNA fragments. Proceedings of the National Academy of Sciences of the United States of America, 110, 15758–15763.2015;522:167–72.",
    "Bind the digests to the MinElute column using reservoirs as previously described (Dabney et al. 2013).",
    "Wash with 800 μl buffer PE (Qiagen).",
    "Elute in 17 μl buffer EB (Qiagen). (1/2)",
    "Incubate for 5 minutes at 37 °C prior to release. (1/2) 00:05:00",
    "Elute in 17 μl buffer EB (Qiagen). (2/2)",
    "Incubate for 5 minutes at 37 °C prior to release. (2/2) 00:05:00",
    "Prior to library construction, analyze small aliquots of each extract on an Agilent 2200 TapeStation HS chip (Agilent Technologies, Palo Alto, California, USA) for fragment size estimation and molar concentration."
  ],
