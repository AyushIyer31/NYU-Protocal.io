\u003e\\u003cb\\u003e\\u003c/b\\u003e  \",\"  \\u003cb\\u003eVendor\\u003c/b\\u003e\\u003cb\\u003e\\u003c/b\\u003e  \",\"  \\u003cb\\u003eCatalog #\\u003c/b\\u003e\\u003cb\\u003e\\u003c/b\\u003e  \"],[\"StemFlex medium\",\"  Thermo\\n  Fisher  \",\"A3349401\"],[\"Y-27632\",\"R\\u0026D Systems\",\"1254\"],[\"Colcemid \",\"Roche\",\"10295892001\"]],\"guid\":\"B824E72B0A4611ED9C510A58A9FEAC02\",\"isJexcelDataFormat\":true,\"legend\":\"\",\"mergeCells\":{},\"printData\":[[\"  \\u003cb\\u003eItem\\u003c/b\\u003e\\u003cb\\u003e\\u003c/b\\u003e  \",\"  \\u003cb\\u003eVendor\\u003c/b\\u003e\\u003cb\\u003e\\u003c/b\\u003e  \",\"  \\u003cb\\u003eCatalog #\\u003c/b\\u003e\\u003cb\\u003e\\u003c/b\\u003e  \"],[\"StemFlex medium\",\"  Thermo\\n  Fisher  \",\"A3349401\"],[\"Y-27632\",\"R\\u0026D Systems\",\"1254\"],[\"Colcemid \",\"Roche\",\"10295892001\"]],\"rowHeights\":[23,23,23,23]}}}}",
  "steps": [
    "iPSCs were dissociated with Accutase and plated at 1x106 cells/well in 6 well plates in StemFlex with 10 μM Y-27632.",
    "24 hours after seeding. iPSCs were treated with Colcemid (1:100, Roche, 10295892001) for 12 hours.",
    "Treated iPSCs were transferred to NHGRI Cytogenetics Core for karyotyping."
