  "materials_text": "{\"blocks\":[{\"key\":\"JdXAH\",\"text\":\"MATERIALS\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":null,\"entityRanges\":null,\"data\":null},{\"key\":\"jvIuG\",\"text\":\" \",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":null,\"entityRanges\":[{\"key\":0,\"offset\":0,\"length\":1}],\"data\":null}],\"entityMap\":{\"0\":{\"type\":\"reagents\",\"mutability\":\"\",\"data\":{\"id\":3428,\"guid\":\"41059E08341F11EE9D4302C0B41BC903\",\"name\":\"Potato Extract Glucose Agar\",\"mol_weight\":0,\"sku\":\"X931.1\",\"url\":\"http://www.carlroth.com\",\"cas_number\":\"\",\"rrid\":\"\",\"vendor\":{\"id\":1,\"name\":\"Contributed by users\",\"link\":\"https://www.protocols.io\",\"is_requested\":false,\"image\":{\"source\":\"/img/vendors/1.png\",\"placeholder\":\"/img/vendors/1.png\"}},\"is_public\":true,\"can_edit\":false}}}}",
  "steps": [
    "Take agar cubes / rains from glycerol stock and place 3-4 pieces on PDA plates When using another plate, scrape of a tiny bit oc mycelium and put 3-4 plugs on the agar plate",
    "Grow for 4-7 days in the dark",
    "Move to UV light, or place in a bright (sunny) spot in the lab for about 3 days",
    "Dislodge the spores by adding small amounts of water on the fluffy mycelium and aspirating it back up. Check spore density under a microscope."
