  "materials_text": "",
  "steps": [
    "Collect eggs from adults of both mitotypes raised on instant food",
    "Posit eggs onto experimental diet",
    "Collect eclosing females as virgins",
    "Place virgins in vials containing experimental diet, with two females per vial",
    "Add one male of each mitotype to vials containing virgin females",
    "After 24 hours move flies to new vials",
    "Repeat step 6",
    "Remove all flies from vials",
    "Allow new generation to eclose",
    "Count number of eclosing adults",
    "Determine fertility as number of eclosing adults per female"
  ],
