  "warning": "{\"blocks\":[{\"key\":\"d5ph\",\"text\":\"\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":[]}],\"entityMap\":{}}",
  "materials_text": "",
  "steps": [
    "Add 1mL lysis buffer to each filter in a 5mL snap cap tubea. Lysis buffer: i. 40mM EDTA ii. 50mM Tris iii. 0.75M sucrose",
    "Incubate 45min at 37°C, shaking gently",
    "Add SDS to 1% v/v (in this case, 100ul of 10% SDS solution was added to each sample)",
    "Incubate 1hr at 55°C, shaking gently",
    "Collect liquid lysate into a 2mL tube",
    "Add 1mL phenol:chloroform:isoamyl alcohol and mix well",
    "Centrifuge 5min at 8000g",
    "Transfer aqueous phase to new 2mL tube",
    "Repeat steps 6-8",
    "Add 1mL chloroform and mix well",
    "Centrifuge 5min at 8000g",
    "Transfer aqueous phase to upper reservoir of a 4mL 100kDa Amicon concentrator",
    "Centrifuge at 1000g until &lt;200ul remains",
    "Add 2mL sterile water to upper reservoir",
    "Vortex for 20sec at 1500rpm",
    "Centrifuge at 1000g until &lt;200ul remains",
    "Repeat steps 14-16",
    "Collect sample from upper reservoir and transfer to 1.5mL tube",
    "Check concentration with Qubit HS DNA assay"
  ],
