  "steps": [
    "Recover samples by pipetting out of aggregation plate",
    "Glow-discharge grids (3-mm 300-mesh (EM Resolutions Ltd))",
    "Take up grid with tweezers",
    "Spot 2.3 µL sample on grid",
    "Stain sample with 2.3 µL 2% uranyl acetate for 40 s at room temperature",
    "Image grids on an electron microscope (FEI Tecnai G2 transmission electron microscope)"
  ],
