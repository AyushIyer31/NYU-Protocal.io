  "materials_text": "{\"blocks\":[{\"key\":\"RQoVn\",\"text\":\"MATERIALS\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":null,\"entityRanges\":null,\"data\":null},{\"key\":\"CiX44\",\"text\":\" \",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":null,\"entityRanges\":[{\"key\":0,\"offset\":0,\"length\":1}],\"data\":null},{\"key\":\"fnjFp\",\"text\":\" \",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":null,\"entityRanges\":[{\"key\":1,\"offset\":0,\"length\":1}],\"data\":null},{\"key\":\"vnz5l\",\"text\":\" \",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":null,\"entityRanges\":[{\"key\":2,\"offset\":0,\"length\":1}],\"data\":null}],\"entityMap\":{\"0\":{\"type\":\"reagents\",\"mutability\":\"\",\"data\":{\"id\":360,\"guid\":\"41013290341F11EE9D4302C0B41BC903\",\"name\":\"Sodium nitrite\",\"mol_weight\":69,\"sku\":\"\",\"url\":\"http://store.p212121.com/sodium-nitrite/?utm_source=zappylab.benchtools\\u0026utm_medium=ios\\u0026utm_campaign=p21nov13\",\"cas_number\":\"\",\"rrid\":\"\",\"vendor\":{\"id\":7,\"name\":\"P212121\",\"link\":\"http://store.p212121.com/\",\"is_requested\":false,\"image\":{\"source\":\"/img/vendors/7.png\",\"placeholder\":\"/img/vendors/7.png\"}},\"is_public\":true,\"can_edit\":false}},\"1\":{\"type\":\"reagents\",\"mutability\":\"\",\"data\":{\"id\":2715,\"guid\":\"4104B54A341F11EE9D4302C0B41BC903\",\"name\":\"MilliQ water\",\"mol_weight\":0,\"sku\":\"\",\"url\":\"\",\"cas_number\":\"\",\"rrid\":\"\",\"vendor\":{\"id\":1,\"name\":\"Contributed by users\",\"link\":\"https://www.protocols.io\",\"is_requested\":false,\"image\":{\"source\":\"/img/vendors/1.png\",\"placeholder\":\"/img/vendors/1.png\"}},\"is_public\":true,\"can_edit\":false}},\"2\":{\"type\":\"reagents\",\"mutability\":\"\",\"data\":{\"id\":3154,\"guid\":\"4105429E341F11EE9D4302C0B41BC903\",\"name\":\"Chelex-100 resin\",\"mol_weight\":0,\"sku\":\"\",\"url\":\"\",\"cas_number\":\"\",\"rrid\":\"\",\"vendor\":{\"id\":1,\"name\":\"Contributed by users\",\"link\":\"https://www.protocols.io\",\"is_requested\":false,\"image\":{\"source\":\"/img/vendors/1.png\",\"placeholder\":\"/img/vendors/1.png\"}},\"is_public\":true,\"can_edit\":false}}}}",
  "steps": [
    "Add 12.9 g of sodium nitrite per 125 mL of Milli-Q, by weighing the sodium nitrite directly into a large trace metal clean bottle.",
    "Add 125 mL of Milli-Q to the bottle by weight.",
    "Add clean Chelex-100 resin to the bottle and place it on a shaker overnight to ensure the Chelex mixes throughout the solution.",
    "The following morning, slowly pour the solution through an HPLC column with a frit in order to filter the chelex and allow the solution to pass into a trace metal clean bottle. Make sure to test the reagent before use to ensure it is clean."
