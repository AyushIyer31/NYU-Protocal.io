  "steps": [
    "Thaw Tissuesections at RT",
    "wash in PBS for 10 minutes 00:10:00",
    "Circle samples with PAP-Pen",
    "Block in 10% Serum for 30 minutes 00:30:00",
    "Add primary Antibody for 90 minutes at RT or o/n at 4C",
    "wash 3x with PBS?",
    "incubate with secondary AB for 60 minutes",
    "wash 3x with PBS?",
    "Add DABCO-Mowiol on samples to increase IF",
    "Mikroskopie!"
