  "steps": [
    "Add Water Contributed by users to ~ 100 µL - 200 µL DNA/RNA solution until a volume of 400 µL is reached.",
    "Add 130 µL 5 Molarity (M) NaCl Merck MilliporeSigma (Sigma-Aldrich) Catalog #53014",
    "Add 1.6 mL mL of CTAB-Urea solution CTAB-Urea buffer by Jason Stajich",
    "Mix samples (by hand).",
    "Incubate overnight at 4 °C Overnight",
    "Centrifuge for 00:15:00 at max speed at 4 °C",
    "Remove the solution. Be very careful in this step!",
    "Resuspended in 400 µL µL 7 Molarity (M) Guanidine hydrochloride Merck MilliporeSigma (Sigma-Aldrich) Catalog #G3272-1KG (CAS: 50-01-1)",
    "Add 2 2 µL, VOLUMES Vol of EtOH (100%)",
    "Incubate on ice for 01:00:00",
    "15300 x g, 4 °C, 15 minutes",
    "Wash with 70% ethanol Fisher Scientific",
    "Wash again with 70% ethanol Fisher Scientific",
    "20800 x g, Room temperature, 10 minutes, (or maximum speed)",
    "Remove the supernatant.",
    "Dry pellet",
    "Resuspend in TE buffer"
  ],
