  "steps": [
    "•Start with 700 mL water",
    "•Add ~60 g of NaOH",
    "•Allow to cool back to room temperature (can speed in room temp water bath)",
    "•Add 146.12 g EDTA",
    "•Adjust pH to 8.0 with 5-10 M NaOH",
    "•Add water to 1000 mL",
    "•Autoclave"
  ],
