":{}},{\"key\":\"kryza\",\"text\":\"\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"foaeh\",\"text\":\"DAPI\\r\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"hvkyb\",\"text\":\"\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"ttco3\",\"text\":\"Mounting media\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"1yjxp\",\"text\":\"\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"w5mlr\",\"text\":\"Equipment\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[{\"style\":\"bold\",\"offset\":0,\"length\":9}],\"entityRanges\":[],\"data\":{}},{\"key\":\"6feea\",\"text\":\"Humidity Chamber\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}}],\"entityMap\":{}}",
  "steps": [
    "Wash cells with PBS.",
    "Fix in 4% PFA for 15 min at room temperature (RT).",
    "Wash cells with PBS (2 x 5 min). Cells can be stored in PBS at 4C for up to a week.",
    "Permeabilize with PBS + 0.1% TritonX-100 for 5 min at RT.",
    "Wash with PBS (2 x 5 min) at RT.",
    "Block with 10% serum (from species of secondary) for 1 hr at RT.",
    "Drain and incubate with primary antibody diluted in 5% serum overnight at 4C.",
    "Wash in PBS (3 x 5 min) at RT.",
    "Detect primary antibody with Alexa Fluor secondary antibody diluted 1:400 in 5% serum at RT for 1 hr in the dark.",
    "Wash in PBS (3 x 5 min) at RT.",
    "Add mounting media with DAPI and apply coverslip.",
    "Store slides in the dark at 4C.",
    "None."
  ],
