  "warning": "{\"blocks\":[{\"key\":\"7vjrc\",\"text\":\"When heating the mixture on the hot plate, make sure to not turn on the heat until the glass beaker is on the plate. Hot plate + cold glass = a bad time!\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}}],\"entityMap\":{}}",
  "materials_text": "{\"blocks\":[{\"key\":\"6tl37\",\"text\":\"Scale\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"8flm9\",\"text\":\"Weigh boat\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"djqcd\",\"text\":\"1L beaker\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"65ad8\",\"text\":\"Distilled water (dH2O)\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"a3v40\",\"text\":\"Sodium chloride (NaCl)\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"9ekf5\",\"text\":\"Potassium phosphate monobasic\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"9g6\",\"text\":\"Sodium phosphate dibasic\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"8scn4\",\"text\":\"Hot plate\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"dfds4\",\"text\":\"Stir bar\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"u4o5\",\"text\":\"1L bottle\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}}],\"entityMap\":{}}",
  "steps": [
    "Fill a 1L beaker with 800mL of dH2O.",
    "Weigh out 9g of NaCl, 3.8g of monobasic, and 10.2g of dibasic. Add these measurements to the beaker.",
    "Place beaker onto the hot plate and heat the solution up to 60°C.",
    "Add stir bar and stir the solution until clear. Pour into a bottle and keep refrigerated.",
    "Add dH2O until the final volume of the solution reaches 1L."
  ],
