  "warning": "",
  "materials_text": "{\"blocks\":[{\"key\":\"eo9j0\",\"text\":\"Materials for fixative preparation:\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"7r884\",\"text\":\"Para-formaldehyde powder (PFA)\",\"type\":\"unordered-list-item\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"3v8bo\",\"text\":\"Phosphate-buffered saline (PBS) tablets\",\"type\":\"unordered-list-item\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"f4rp3\",\"text\":\"1M NaOH\",\"type\":\"unordered-list-item\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"3si6d\",\"text\":\"Glycerol\",\"type\":\"unordered-list-item\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}}],\"entityMap\":{}}",
  "steps": [
    "Weigh 1.6 g PFA powder",
    "Dissolve in 20 mL of DI water",
    "Incubate in water bath at 60 °C to help dissolve PFA powder for 00:40:00",
    "Add 20 µL of 1 M NaOH to further help dissolve PFA powder",
    "Place back in 60 °C water bath for 00:10:00",
    "Pull out of water bath and cool to Room temperature",
    "Add two tablets of PBS to a 100 mL volumetric flask",
    "Mix 20 mL of each solution to get 4% formaldehyde",
    "Add 400 µL of glycerol to fixative",
    "Ensure pH 7.5",
    "Place fixative in a hot water bath till 60 °C",
    "If still not dissolved, add 10 µL more of 1M NaOH"
  ],
