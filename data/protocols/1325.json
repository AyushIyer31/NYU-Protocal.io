  "materials_text": "",
  "steps": [
    "Dilute 5mL O/N into 500mL LB.",
    "Grow to OD 0.6­-0.8 (~1.5­-3 hours).",
    "Pour into 2x250mL Centrifuge bottles.",
    "Chill bottles on ice for 10 minutes. 00:10:00",
    "Spin at 3000xg for 20min at 4C. 00:20:00",
    "Decant supernatant.",
    "Resuspend + combine pellets in 250mL pre­chilled 10% glycerol. You can do 2x125 mL also, if it is easier to balance for centrifuge.",
    "Spin at 3000xg for 20min at 4C. 00:20:00",
    "Decant supernatant.",
    "Resuspend pellet in 20mL pre­chilled 10% glycerol (switch to 50mL Falcon Tube).",
    "Spin at 3000xg for 20min at 4C. 00:20:00",
    "Decant supernatant.",
    "Resuspend in 3mL pre­chilled 10% glycerol.",
    "SNAP Freeze in 25­50uL aliquots in LN2."
  ],
