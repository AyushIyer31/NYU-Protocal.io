  "description": "{\"blocks\":[{\"key\":\"d3fqc\",\"text\":\"Summary: \",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[{\"style\":\"bold\",\"offset\":0,\"length\":8}],\"entityRanges\":[],\"data\":{}},{\"key\":\"59k82\",\"text\":\"\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"3alhj\",\"text\":\"Triglyceride emulsion and heparin will be intravenously infused for 5 hours to acutely raise circulating fatty acids levels in awake mice. Acute lipid infusion is shown to cause insulin resistance in peripheral organs.\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}}],\"entityMap\":{}}",
