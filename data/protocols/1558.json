  "steps": [
    "2µl 10x CutSmart buffer",
    "2 µl T4 DNA ligase buffer",
    "100ng of each pU6x-sgRNA plasmid",
    "50ng empty pGGDestTol2LC-sgRNA vector of choice (see plasmid list and diagrams in Guidelines),",
    "1µl BsaI",
    "1µl T4 DNA ligase",
    "adjust volume to 20µl with H2O"
