  "materials_text": "{\"blocks\":[{\"key\":\"bu1qj\",\"text\":\"1L beaker\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"ck8eu\",\"text\":\"PBS\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"5ekuv\",\"text\":\"Triton X-100\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"8cgfv\",\"text\":\"1000 μL micropipette\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"alapp\",\"text\":\"Stir plate\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"3vmoo\",\"text\":\"Stir bar\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"fm3ve\",\"text\":\"1L bottle\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}}],\"entityMap\":{}}",
  "steps": [
    "Add 100 mL of PBS to your 1 L beaker and place beaker on stir plate. Add a stir bar.",
    "Pipette 3000 μL of Triton X-100 into the beaker and stir until completely dissolved. It may help to break up the Triton X-100 by mixing larger pieces using the micropipette before activating the stir bar.",
    "Once completely incorporated, add the remaining 900 mL of PBS to the 1 L beaker and stir until clear and no visible Triton X-100 remains.",
    "Pour the solution into the 1 L bottle and store in the refrigerator."
  ],
