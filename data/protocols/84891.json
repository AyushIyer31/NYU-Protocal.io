  "materials_text": "{\"blocks\":[{\"key\":\"cies1\",\"text\":\"Reagents\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[{\"style\":\"bold\",\"offset\":0,\"length\":8}],\"entityRanges\":[],\"data\":{}},{\"key\":\"91g59\",\"text\":\"\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"aee3n\",\"text\":\" \",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[{\"key\":0,\"offset\":0,\"length\":1}],\"data\":{}},{\"key\":\"d3v87\",\"text\":\"  \",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[{\"key\":1,\"offset\":0,\"length\":1}],\"data\":{}},{\"key\":\"28crk\",\"text\":\"\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}}],\"entityMap\":{\"0\":{\"type\":\"reagents\",\"mutability\":\"MUTABLE\",\"data\":{\"id\":960071,\"guid\":\"437B1B87341F11EE9D4302C0B41BC903\",\"name\":\"Carmine\",\"mol_weight\":0,\"sku\":\"C1022\",\"url\":\"https://www.sigmaaldrich.com/US/en/product/sigma/c1022\",\"cas_number\":\"1390-65-4\",\"rrid\":\"\",\"vendor\":{\"id\":17,\"name\":\"Merck MilliporeSigma (Sigma-Aldrich)\",\"link\":\"http://sigmaaldrich.com\",\"is_requested\":false,\"image\":{\"source\":\"/img/vendors/placeholder.png\",\"placeholder\":\"/img/vendors/placeholder.png\"}},\"is_public\":true,\"can_edit\":false}},\"1\":{\"type\":\"reagents\",\"mutability\":\"MUTABLE\",\"data\":{\"id\":960074,\"guid\":\"437B1C7F341F11EE9D4302C0B41BC903\",\"name\":\"0.5% methylcellulose\",\"mol_weight\":0,\"sku\":\"M0512\",\"url\":\"https://www.sigmaaldrich.com/GB/en/product/sigma/m0512\",\"cas_number\":\"\",\"rrid\":\"\",\"vendor\":{\"id\":17,\"name\":\"Merck MilliporeSigma (Sigma-Aldrich)\",\"link\":\"http://sigmaaldrich.com\",\"is_requested\":false,\"image\":{\"source\":\"/img/vendors/placeholder.png\",\"placeholder\":\"/img/vendors/placeholder.png\"}},\"is_public\":true,\"can_edit\":false}}}}",
  "steps": [
    "Prepare a sterile solution of carmine red (300 µl; 6%; Sigma-Aldrich, Cat #C1022; St Louis, MO) suspended in 0.5% methylcellulose (Sigma-Aldrich, Cat #M0512; St Louis, MO).",
    "Administer 0.3 mL of carmine red solution by gavage through a 21-gauge round-tip feedingneedle.",
    "The time at which gavage takes place is recorded as T 0 .",
    "Place each mouse in separate cages without bedding.",
    "01:00:00 after gavage, monitor fecal pellets at 00:10:00 intervals for the presence of carmine red. Total GI transit time is considered as the interval between T 0 and the time of first observance of carmine red in the stool."
  ],
