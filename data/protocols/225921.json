  "warning": "{\"blocks\":[{\"key\":\"7lfjl\",\"text\":\"Do not inhale PFA powder, all mixing and weighing should take place under the fume hood\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}}],\"entityMap\":{}}",
  "materials_text": "{\"blocks\":[{\"key\":\"77gb6\",\"text\":\"Scale\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"card3\",\"text\":\"Weigh boat\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"ebb02\",\"text\":\"1L beaker\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"7i5kq\",\"text\":\"PBS\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"bdc84\",\"text\":\"Paraformaldehyde powder\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"76dvh\",\"text\":\"Sodium Hydroxide (NaOH)\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"98s3d\",\"text\":\"Coffee filters\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"24jb1\",\"text\":\"Funnel\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"57u00\",\"text\":\"Hot plate\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"7osn9\",\"text\":\"Stir bar\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"523ie\",\"text\":\"Thermometer\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"bgnad\",\"text\":\"1L bottle\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}}],\"entityMap\":{}}",
  "steps": [
    "Add 800mL of PBS to your 1L beaker and place beaker on hot plate under the fume hood. Add a stir bar and heat while stirring up to 60°C.",
    "Weigh out 40g of paraformaldehyde powder and add it to the beaker. The mixture will be very cloudy and will not clear right away.",
    "Gradually raise the pH of the solution by adding drops of NaOH from a pipette until the solution clears. Once the solution is clear and paraformaldehyde has been dissolved, leave the solution to cool.",
    "Once cooled, filter the solution through the coffee filter into your 1L bottle using a funnel.",
    "Adjust the volume of the bottle up to 1L by adding PBS.",
    "Store and refrigerate up to one month."
  ],
