  "materials_text": "{\"blocks\":[{\"key\":\"2f006\",\"text\":\"200 ng of RNA\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":[]},{\"key\":\"7rsoo\",\"text\":\"preferred cDNA synthesis Kir \",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":[]},{\"key\":\"bon2m\",\"text\":\"\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":[]}],\"entityMap\":{}}",
  "steps": [
    "for cDNA synthesis, we use the BioRad iScript cDNA synthesis Kit (Cat.# 1708891)",
    "use 50ng/uL of RNA for reaction, up to 1 ug total RNA per reaction volume (20 uL)",
    "thermal cycler program: priming for 5 mins at 25C, reverse transcription for 20 mins at 46C, inactivation for 1 min at 95C, and an optional hold step at 4C.",
    "used directly or stored at -20° C"
