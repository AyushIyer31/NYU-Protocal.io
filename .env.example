# Protocols.io RAG Backend Environment Configuration
# Copy to protocolsnerd-backend/variables.env and fill in your values

# ============================================================================
# LLM PROVIDERS
# ============================================================================

# OpenAI (default)
OPENAI_API_KEY=sk-...

# Anthropic Claude (optional)
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (optional)
GOOGLE_GENAI_API_KEY=...

# Protocols.io API (required for live search)
PROTOCOLS_IO_TOKEN=...

# ============================================================================
# LLM SELECTION
# ============================================================================

# Which LLM to use: "openai" (default), "claude", "gemini", "ollama"
LLM_PROVIDER=openai

# ============================================================================
# LOCAL LLM (Ollama)
# ============================================================================

# If using local Ollama instead of cloud providers
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ============================================================================
# DATABASE (Optional - not used by default)
# ============================================================================

# DATABASE_URL=postgresql://user:password@localhost/protocols_io

# ============================================================================
# DEPLOYMENT
# ============================================================================

# Environment: development, staging, production
ENVIRONMENT=production

# Backend host (used by frontend API calls)
BACKEND_HOST=https://protocolnerds.com

# Port for local development
PORT=8001

# ============================================================================
# SESSIONS & STORAGE
# ============================================================================

# Directory for storing session data
SESSIONS_DIR=storage/sessions

# ============================================================================
# SEARCH CONFIGURATION
# ============================================================================

# Number of results to fetch per provider (protocols.io, PubMed)
RESULTS_PER_PROVIDER=5

# Top-k results for local indexed search
LOCAL_SEARCH_TOP_K=120

# Top-k results for live protocols.io search
LIVE_SEARCH_TOP_K=50

# Enable PubMed search (requires internet access)
PUBMED_ENABLED=true

# ============================================================================
# OPTIONAL: EXTERNAL SERVICES
# ============================================================================

# Slack notifications for errors (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Email for error reports (optional)
ADMIN_EMAIL=admin@example.com

# ============================================================================
# DEBUG & LOGGING
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable request/response logging (verbose)
DEBUG=false
